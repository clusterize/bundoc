{
  "name": "@clusterize/bundoc",
  "version": "0.2.3",
  "description": "A modern bring-your-own-components documentation framework built with Bun and MDX.",
  "keywords": [
    "documentation",
    "generator",
    "static-site",
    "mdx",
    "markdown",
    "react",
    "bun"
  ],
  "homepage": "https://bundoc.dev",
  "bugs": "https://github.com/clusterize/bundoc/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clusterize/bundoc.git"
  },
  "license": "MIT",
  "author": "Loïc Nestler <loic@clusterize.co>",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./theme": "./src/theme/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./mdx-plugin": "./src/mdx/bun-plugin.ts"
  },
  "bin": {
    "bundoc": "./src/cli/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.html",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!src/**/__fixtures__/**",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "bundoc": "bun src/cli/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@orama/orama": "^3.1.18",
    "@shikijs/rehype": "^4.0.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-mdx-frontmatter": "^5.0.0",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2"
  }
}
